{
  "files.associations": {
    "*.yaml": "yaml",
    "*.yml": "yaml"
  },
  "ansible.ansible.enabled": false,
  "ansible.lightspeed.enabled": false,
  "terraform.languageServer.enable": false,
  "docker.enableDockerfileLanguageFeatures": false,
  "yaml.validate": true,
  "yaml.completion": true,
  "vs-kubernetes.enable": true,
  "yaml.schemas": {
    "https://raw.githubusercontent.com/compose-spec/compose-spec/master/schema/compose-spec.json": [
      "docker-compose.yml",
      "docker-compose.yaml",
      "compose.yml",
      "compose.yaml"
    ],
    "kubernetes": [
      "**/*.yaml",
      "**/*.yml"
    ]
  },
  "yaml.customTags": []
}
